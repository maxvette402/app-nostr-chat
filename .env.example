# Web app port (served by nginx inside Docker)
WEB_PORT=3000

# Comma-separated default relay URLs
DEFAULT_RELAYS=wss://relay.damus.io,wss://relay.nostr.band,wss://nos.lol

# Blossom file storage server URL
BLOSSOM_SERVER_URL=http://localhost:3001

# Self-hosted strfry relay port (optional)
STRFRY_PORT=7777

# Node environment
NODE_ENV=production

# Vite build-time env vars (prefix with VITE_ to expose to browser)
VITE_DEFAULT_RELAYS=wss://relay.damus.io,wss://relay.nostr.band,wss://nos.lol
VITE_BLOSSOM_SERVER_URL=http://localhost:3001
